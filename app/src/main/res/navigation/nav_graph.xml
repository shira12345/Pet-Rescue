<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/nav_graph"
  app:startDestination="@id/loginFragment">

  <fragment
    android:id="@+id/loginFragment"
    android:name="com.example.petrescue.LoginFragment"
    android:label="Login"
    tools:layout="@layout/fragment_login">
    <action
      android:id="@+id/action_loginFragment_to_registerFragment"
      app:destination="@id/registerFragment" />
    <action
      android:id="@+id/action_loginFragment_to_feedFragment"
      app:destination="@id/feedFragment"
      app:popUpTo="@id/nav_graph"
      app:popUpToInclusive="true" />
  </fragment>

  <fragment
    android:id="@+id/registerFragment"
    android:name="com.example.petrescue.RegisterFragment"
    android:label="Register"
    tools:layout="@layout/fragment_register">
    <action
      android:id="@+id/action_registerFragment_to_feedFragment"
      app:destination="@id/feedFragment"
      app:popUpTo="@id/nav_graph"
      app:popUpToInclusive="true" />
  </fragment>

  <fragment
    android:id="@+id/feedFragment"
    android:name="com.example.petrescue.features.posts_feed.FeedFragment"
    android:label="Home"
    tools:layout="@layout/fragment_feed">
    <action
      android:id="@+id/action_feedFragment_to_postDetailsFragment"
      app:destination="@id/postDetailsFragment" />
    <action
      android:id="@+id/action_feedFragment_to_createPostFragment"
      app:destination="@id/createPostFragment" />
  </fragment>

  <fragment
    android:id="@+id/postDetailsFragment"
    android:name="com.example.petrescue.PostDetailsFragment"
    android:label="Post Details"
    tools:layout="@layout/fragment_post_details">
    <argument
      android:name="petName"
      app:argType="string" />
    <argument
      android:name="petType"
      app:argType="string" />
    <argument
      android:name="breed"
      app:argType="string"
      app:nullable="true" />
    <argument
      android:name="status"
      app:argType="string" />
    <argument
      android:name="description"
      app:argType="string" />
    <argument
      android:name="imageUri"
      app:argType="string"
      app:nullable="true" />
  </fragment>

  <fragment
    android:id="@+id/profileFragment"
    android:name="com.example.petrescue.ProfileFragment"
    android:label="Profile"
    tools:layout="@layout/fragment_profile">
    <argument
      android:name="username"
      android:defaultValue="@null"
      app:argType="string"
      app:nullable="true" />
    <argument
      android:name="email"
      android:defaultValue="@null"
      app:argType="string"
      app:nullable="true" />
    <action
      android:id="@+id/action_profileFragment_to_loginFragment"
      app:destination="@id/loginFragment"
      app:popUpTo="@id/nav_graph"
      app:popUpToInclusive="true" />
  </fragment>

  <fragment
    android:id="@+id/createPostFragment"
    android:name="com.example.petrescue.features.create_post.CreatePostFragment"
    android:label="CreatePostFragment">
    <action
      android:id="@+id/action_createPostFragment_to_feedFragment"
      app:destination="@id/feedFragment" />
  </fragment>

</navigation>